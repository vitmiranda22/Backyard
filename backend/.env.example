# Copy this file to .env and fill in your own values.
# See docs/API_SETUP_GUIDE.md for how to get each of these.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# OpenAI (AI narration)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Google Cloud Text-to-Speech
# -----------------------------------------------------------------------------
GOOGLE_TTS_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (audio file storage)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=backyard-audio

# -----------------------------------------------------------------------------
# TMDb (optional — free key from https://www.themoviedb.org/settings/api)
# Leave blank to skip the TMDb zone-data source entirely.
# -----------------------------------------------------------------------------
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
DAILY_NARRATION_LIMIT=50
MINUTE_NARRATION_LIMIT=5

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
