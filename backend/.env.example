# Copy this file to .env and fill in your own values.
# See docs/API_SETUP_GUIDE.md for how to get each of these.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# OpenAI (AI narration)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Google Cloud Text-to-Speech
# -----------------------------------------------------------------------------
GOOGLE_TTS_API_KEY=

# -----------------------------------------------------------------------------
# Google Street View Static API (zone photos)
# -----------------------------------------------------------------------------
GOOGLE_STREETVIEW_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (audio file storage)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=backyard-audio

# -----------------------------------------------------------------------------
# TMDb (optional — free key from https://www.themoviedb.org/settings/api)
# Leave blank to skip the TMDb zone-data source entirely.
# -----------------------------------------------------------------------------
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# GeoNames (optional — free username from https://www.geonames.org/login —
# register, confirm by email, then enable the free webservice on your
# account page). Leave blank to skip the GeoNames zone-data source entirely.
# -----------------------------------------------------------------------------
GEONAMES_USERNAME=

# -----------------------------------------------------------------------------
# Europeana (optional — free API key from https://pro.europeana.eu/get-api)
# Leave blank to skip the Europeana zone-data source entirely.
# -----------------------------------------------------------------------------
EUROPEANA_API_KEY=

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
DAILY_NARRATION_LIMIT=250
MINUTE_NARRATION_LIMIT=15

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Crash reporting (optional — leave blank to disable Sentry entirely)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# RevenueCat webhook (optional — leave blank to reject all webhook calls).
# Set this same value as the Authorization header (as "Bearer <value>") when
# configuring the webhook in the RevenueCat dashboard: Project Settings >
# Integrations > Webhooks.
# -----------------------------------------------------------------------------
REVENUECAT_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# ElevenLabs (optional — powers only the "Signature" voice's cached preview
# sample for now, not real narration). Get an API key from
# elevenlabs.io/app/settings/api-keys, and a voice ID from a voice in your
# Voice Library (elevenlabs.io/app/voice-library) or Voices page.
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
